model Ledger {
  id             String             @id @default(cuid())
  name           String
  type           LedgerType
  amount         Decimal            @default(0) @db.Decimal(15, 2)
  date           DateTime           @default(now())
  isActive       Boolean            @default(true)
  description    String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  organizationId String
  expenses       Expense[]
  journalLines   JournalEntryLine[]
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([type])
  @@map("ledger")
}

model TaxRate {
  id                      String                   @id @default(cuid())
  name                    String
  rate                    Decimal                  @db.Decimal(5, 2)
  cgstRate                Decimal?                 @db.Decimal(5, 2)
  sgstRate                Decimal?                 @db.Decimal(5, 2)
  igstRate                Decimal?                 @db.Decimal(5, 2)
  isCompositionScheme     Boolean                  @default(false)
  description             String?
  organizationId          String
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  hsnCodes                HSNCode[]
  invoiceItems            InvoiceItem[]
  quotationItems          QuotationItem[]
  salesOrderItems         SalesOrderItem[]
  creditNoteItems         CreditNoteItem[]
  purchaseOrderItems      PurchaseOrderItem[]
  purchaseBillItems       PurchaseBillItem[]
  supplierCreditNoteItems SupplierCreditNoteItem[]
  debitNoteItems          DebitNoteItem[]
  items                   Item[]
  organization            Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([rate])
  @@map("tax_rate")
}

model HSNCode {
  id                      String                   @id @default(cuid())
  code                    String
  description             String
  organizationId          String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  defaultTaxRateId        String?
  isSystemCode            Boolean                  @default(false)
  defaultTaxRate          TaxRate?                 @relation(fields: [defaultTaxRateId], references: [id])
  organization            Organization?            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoiceItems            InvoiceItem[]
  quotationItems          QuotationItem[]
  salesOrderItems         SalesOrderItem[]
  creditNoteItems         CreditNoteItem[]
  purchaseOrderItems      PurchaseOrderItem[]
  purchaseBillItems       PurchaseBillItem[]
  supplierCreditNoteItems SupplierCreditNoteItem[]
  debitNoteItems          DebitNoteItem[]
  items                   Item[]

  @@unique([code, organizationId], name: "unique_hsn_code_per_organization")
  @@index([organizationId])
  @@index([defaultTaxRateId])
  @@map("hsn_code")
}

model JournalEntry {
  id             String             @id @default(cuid())
  date           DateTime           @default(now())
  type           JournalEntryType
  referenceId    String?
  referenceType  String? // e.g. INVOICE, PURCHASE_BILL
  notes          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  organizationId String
  lines          JournalEntryLine[]
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, date(sort: Desc)])
  @@map("journal_entry")
}

model JournalEntryLine {
  id             String  @id @default(cuid())
  journalEntryId String
  ledgerId       String
  debit          Decimal @default(0) @db.Decimal(15, 2)
  credit         Decimal @default(0) @db.Decimal(15, 2)
  description    String?

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  ledger       Ledger       @relation(fields: [ledgerId], references: [id], onDelete: Restrict)
  costCenterId String?
  costCenter   CostCenter?  @relation(fields: [costCenterId], references: [id])

  @@index([journalEntryId])
  @@index([ledgerId])
  @@index([costCenterId])
  @@map("journal_entry_line")
}

model Expense {
  id             String       @id @default(cuid())
  description    String
  amount         Decimal      @db.Decimal(14, 2)
  date           DateTime     @default(now())
  receipt        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organizationId String
  supplierId     String?
  ledgerId       String?
  ledger         Ledger?      @relation(fields: [ledgerId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplier       Supplier?    @relation(fields: [supplierId], references: [id])

  @@index([organizationId])
  @@map("expense")
}

model CostCenter {
  id             String             @id @default(cuid())
  name           String
  code           String?
  description    String?
  organizationId String
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  journalLines   JournalEntryLine[]

  @@unique([organizationId, name])
  @@map("cost_center")
}

model BankAccount {
  id             String          @id @default(cuid())
  accountName    String
  accountNumber  String
  accountType    String? // SAVINGS, CURRENT
  bankName       String
  branchName     String?
  ifscCode       String?
  currency       String          @default("INR")
  openingBalance Decimal         @default(0) @db.Decimal(15, 2)
  organizationId String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  statements     BankStatement[]

  @@unique([organizationId, accountNumber])
  @@map("bank_account")
}

model BankStatement {
  id             String              @id @default(cuid())
  bankAccountId  String
  statementDate  DateTime
  startDate      DateTime
  endDate        DateTime
  openingBalance Decimal             @db.Decimal(15, 2)
  closingBalance Decimal             @db.Decimal(15, 2)
  isReconciled   Boolean             @default(false)
  organizationId String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  bankAccount    BankAccount         @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lines          BankStatementLine[]

  @@map("bank_statement")
}

model BankStatementLine {
  id              String        @id @default(cuid())
  bankStatementId String
  date            DateTime
  description     String
  reference       String?
  debit           Decimal       @default(0) @db.Decimal(15, 2)
  credit          Decimal       @default(0) @db.Decimal(15, 2)
  isMatched       Boolean       @default(false)
  matchedEntityId String? // ID of JournalEntryLine or Payment
  bankStatement   BankStatement @relation(fields: [bankStatementId], references: [id], onDelete: Cascade)

  @@index([bankStatementId])
  @@index([isMatched])
  @@map("bank_statement_line")
}
