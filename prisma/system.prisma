// ====== SYSTEM ENGINES ======

// ====== API KEY MANAGEMENT ======

model ApiKey {
  id     String @id @default(cuid())
  name   String
  key    String @unique @db.VarChar(255)
  secret String @db.VarChar(255)
  prefix String @default("sk_live") // sk_live_ or sk_test_

  // Scoping
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      String
  creator        User         @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  // Permissions
  permissions String[] @default(["read:items", "read:suppliers"])

  // Security
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  isActive   Boolean   @default(true)

  // Tracking
  usageCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  usageLogs ApiKeyUsageLog[]

  @@index([organizationId])
  @@index([key])
  @@map("api_key")
}

model ApiKeyUsageLog {
  id       String @id @default(cuid())
  apiKeyId String
  apiKey   ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  method   String // GET, POST, etc.
  endpoint String // /api/v1/items
  status   Int // 200, 401, 429, etc.

  ipAddress    String
  userAgent    String?
  responseTime Int // ms

  createdAt DateTime @default(now())

  @@index([apiKeyId, createdAt])
  @@map("api_key_usage_log")
}

model FileUpload {
  id             String       @id @default(cuid())
  key            String       @unique
  name           String
  url            String       @unique
  size           Int
  fileType       String
  uploadedById   String?
  organizationId String
  entityType     String?
  entityId       String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy     User?        @relation(fields: [uploadedById], references: [id])

  documentAttachments DocumentAttachment[]

  @@index([uploadedById])
  @@index([organizationId])
  @@index([entityType, entityId])
}

model DocumentSeries {
  id             String             @id @default(cuid())
  organizationId String
  type           DocumentSeriesType
  name           String
  prefix         String?
  suffix         String?
  padding        Int                @default(5)
  nextNumber     Int                @default(1)
  fiscalYear     String?
  isDefault      Boolean            @default(false)
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  quotations       Quotation[]
  salesOrders      SalesOrder[]
  deliveryChallans DeliveryChallan[]
  creditNotes      CreditNote[]

  purchaseOrders      PurchaseOrder[]
  goodsReceiptNotes   GoodsReceiptNote[]
  purchaseBills       PurchaseBill[]
  supplierCreditNotes SupplierCreditNote[]
  debitNotes          DebitNote[]

  @@unique([organizationId, type, name])
  @@index([organizationId, type])
  @@map("document_series")
}

model ApprovalRequest {
  id             String         @id @default(cuid())
  organizationId String
  status         ApprovalStatus @default(PENDING)
  entityType     String
  entityId       String
  requestedById  String
  approvedById   String?
  note           String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requestedBy    User           @relation("ApprovalRequestedBy", fields: [requestedById], references: [id], onDelete: Cascade)
  approvedBy     User?          @relation("ApprovalApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([entityType, entityId])
  @@map("approval_request")
}

model DocumentAttachment {
  id             String       @id @default(cuid())
  organizationId String
  entityType     String
  entityId       String
  fileUploadId   String
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  file           FileUpload   @relation(fields: [fileUploadId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([entityType, entityId])
  @@index([fileUploadId])
  @@map("document_attachment")
}

model AddressSnapshot {
  id             String       @id @default(cuid())
  organizationId String
  name           String?
  line1          String?
  line2          String?
  city           String?
  state          String?
  pincode        String?
  country        String?
  phone          String?
  gstin          String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  quotationBillingAddresses      Quotation[]       @relation("QuotationBillingAddress")
  quotationShippingAddresses     Quotation[]       @relation("QuotationShippingAddress")
  salesOrderBillingAddresses     SalesOrder[]      @relation("SalesOrderBillingAddress")
  salesOrderShippingAddresses    SalesOrder[]      @relation("SalesOrderShippingAddress")
  deliveryChallanShippingAddress DeliveryChallan[] @relation("DeliveryChallanShippingAddress")

  purchaseOrderBillingAddresses   PurchaseOrder[]    @relation("PurchaseOrderBillingAddress")
  purchaseOrderShippingAddresses  PurchaseOrder[]    @relation("PurchaseOrderShippingAddress")
  goodsReceiptNoteShippingAddress GoodsReceiptNote[] @relation("GoodsReceiptNoteShippingAddress")
  purchaseBillBillingAddresses    PurchaseBill[]     @relation("PurchaseBillBillingAddress")
  purchaseBillShippingAddresses   PurchaseBill[]     @relation("PurchaseBillShippingAddress")

  @@index([organizationId])
  @@map("address_snapshot")
}

model AuditLog {
  id             String       @id @default(cuid())
  action         String
  entityId       String
  entityType     String
  description    String?
  changes        Json?
  metadata       Json? // Additional context data (IP, user agent, etc.)
  createdAt      DateTime     @default(now())
  userId         String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  performedBy    User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([entityId, entityType])
  @@index([userId, createdAt])
  @@index([organizationId, createdAt])
  @@index([organizationId, entityType, entityId])
  @@index([organizationId, userId, createdAt])
  @@map("audit_log")
}

model CustomFieldDefinition {
  id             String             @id @default(cuid())
  organizationId String
  entityType     String // ITEM, CUSTOMER, INVOICE, etc.
  name           String
  label          String
  fieldType      CustomFieldType
  isRequired     Boolean            @default(false)
  defaultValue   String?
  options        Json? // For SELECT type
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  values         CustomFieldValue[]

  @@unique([organizationId, entityType, name])
  @@map("custom_field_definition")
}

model CustomFieldValue {
  id           String                @id @default(cuid())
  definitionId String
  entityId     String
  value        String
  definition   CustomFieldDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@index([definitionId])
  @@index([entityId])
  @@map("custom_field_value")
}

model Workflow {
  id             String          @id @default(cuid())
  organizationId String
  name           String
  entityType     String // PURCHASE_ORDER, INVOICE, etc.
  description    String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  steps          WorkflowStep[]
  stages         WorkflowStage[]

  @@map("workflow")
}

model WorkflowStep {
  id             String           @id @default(cuid())
  workflowId     String
  name           String
  order          Int
  approverRole   String?
  approverUserId String?
  condition      Json? // e.g. amount > 5000
  workflow       Workflow         @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  actions        WorkflowAction[]

  @@map("workflow_step")
}

model WorkflowStage {
  id            String           @id @default(cuid())
  workflowId    String
  entityId      String
  currentStepId String?
  status        String           @default("PENDING")
  workflow      Workflow         @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  actions       WorkflowAction[]

  @@index([entityId])
  @@map("workflow_stage")
}

model WorkflowAction {
  id            String             @id @default(cuid())
  stageId       String
  stepId        String
  action        WorkflowActionType
  performedById String
  comment       String?
  createdAt     DateTime           @default(now())
  stage         WorkflowStage      @relation(fields: [stageId], references: [id], onDelete: Cascade)
  step          WorkflowStep       @relation(fields: [stepId], references: [id], onDelete: Cascade)
  performedBy   User               @relation(fields: [performedById], references: [id])

  @@map("workflow_action")
}

model WebhookSubscription {
  id             String               @id @default(cuid())
  organizationId String
  event          String // invoice.created, stock.low, etc.
  targetUrl      String
  secret         String?
  isActive       Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  logs           WebhookDeliveryLog[]

  @@map("webhook_subscription")
}

model WebhookDeliveryLog {
  id             String              @id @default(cuid())
  subscriptionId String
  statusCode     Int?
  payload        Json
  response       String?
  duration       Int? // ms
  isSuccess      Boolean
  createdAt      DateTime            @default(now())
  subscription   WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, createdAt])
  @@map("webhook_delivery_log")
}

model CurrencyExchangeRate {
  id           String   @id @default(cuid())
  fromCurrency String // e.g. "USD"
  toCurrency   String // e.g. "INR"
  rate         Decimal  @db.Decimal(15, 6)
  date         DateTime @default(now()) // To keep historical rates

  @@index([fromCurrency, toCurrency, date])
  @@map("currency_exchange_rate")
}
