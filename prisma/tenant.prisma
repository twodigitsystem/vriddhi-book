model Organization {
  id                  String                        @id @default(cuid())
  name                String
  slug                String                        @unique
  logo                String?
  createdAt           DateTime                      @default(now())
  metadata            String?
  businessAddress     String?
  businessDescription String?
  businessType        String?
  country             String?                       @default("India")
  baseCurrency        String                        @default("INR")
  language            String                        @default("en")
  fiscalYearStart     Int                           @default(4) // 1 = Jan, 4 = April, etc.
  taxSystem           String? // GST, VAT, SALES_TAX
  dateFormat          String                        @default("DD/MM/YYYY")
  gstin               String?
  phoneNumber         String?
  pincode             String?
  state               String?
  timeZone            String?                       @default("Asia/Kolkata")
  updatedAt           DateTime                      @updatedAt
  businessIndustry    String?
  customerCategories  CustomerCategory[]
  fileUploads         FileUpload[]
  payments            Payment[]
  auditLogs           AuditLog[]
  brands              Brand[]
  categories          Category[]
  customers           Customer[]
  designations        Designation[]
  expenses            Expense[]
  hsnCodes            HSNCode[]
  invitations         Invitation[]
  invoices            Invoice[]
  items               Item[]
  itemSettings        ItemSettings?
  inventorySetting    OrganizationInventorySetting?
  ledgers             Ledger[]
  members             Member[]
  organizationRoles   OrganizationRole[]
  serialNumbers       SerialNumber[]
  stockMovements      StockMovement[]
  suppliers           Supplier[]
  taxRates            TaxRate[]
  journalEntries      JournalEntry[]
  unitConversions     UnitConversion[]
  units               Unit[]
  warehouses          Warehouse[]

  // New relations
  apiKeys          ApiKey[]
  securityPolicy   SecurityPolicy?
  compliancePolicy CompliancePolicy?
  notifications    Notification[]
  dataExports      DataExportRequest[]

  documentSeries      DocumentSeries[]
  approvalRequests    ApprovalRequest[]
  documentAttachments DocumentAttachment[]
  addressSnapshots    AddressSnapshot[]

  quotations       Quotation[]
  salesOrders      SalesOrder[]
  deliveryChallans DeliveryChallan[]
  creditNotes      CreditNote[]

  purchaseOrders      PurchaseOrder[]
  goodsReceiptNotes   GoodsReceiptNote[]
  purchaseBills       PurchaseBill[]
  supplierCreditNotes SupplierCreditNote[]
  debitNotes          DebitNote[]

  // Enterprise relations
  stockValuationLayers   StockValuationLayer[]
  costCenters            CostCenter[]
  bankAccounts           BankAccount[]
  bankStatements         BankStatement[]
  customFieldDefinitions CustomFieldDefinition[]
  workflows              Workflow[]
  webhookSubscriptions   WebhookSubscription[]
  subscription           OrganizationSubscription?

  @@map("organization")
}

model OrganizationInventorySetting {
  id                          String                   @id @default(cuid())
  organizationId              String                   @unique
  salesStockPostingDefault    SalesStockPostingMode    @default(INVOICE)
  purchaseStockPostingDefault PurchaseStockPostingMode @default(PURCHASE_BILL)
  createdAt                   DateTime                 @default(now())
  updatedAt                   DateTime                 @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_inventory_setting")
}

model Member {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           String
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  email          String
  role           String?
  status         String
  expiresAt      DateTime
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

model OrganizationRole {
  id             String       @id @default(cuid())
  slug           String?      @unique
  role           String
  permission     Json
  description    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdBy String?

  @@index([organizationId])
  @@index([organizationId, role])
  @@map("organization_role")
}

model SubscriptionPlan {
  id            String                     @id @default(cuid())
  name          String
  slug          String                     @unique
  description   String?
  price         Decimal                    @db.Decimal(10, 2)
  currency      String                     @default("INR")
  interval      String                     @default("monthly") // monthly, yearly
  features      Json
  isActive      Boolean                    @default(true)
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt
  subscriptions OrganizationSubscription[]

  @@map("subscription_plan")
}

model OrganizationSubscription {
  id                String             @id @default(cuid())
  organizationId    String             @unique
  planId            String
  status            SubscriptionStatus @default(TRIALING)
  startDate         DateTime           @default(now())
  endDate           DateTime?
  trialEndsAt       DateTime?
  cancelAtPeriodEnd Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan              SubscriptionPlan   @relation(fields: [planId], references: [id])
  usageMetrics      UsageMetric[]

  @@map("organization_subscription")
}

model UsageMetric {
  id             String                   @id @default(cuid())
  subscriptionId String
  metricName     String // e.g. "invoice_count", "member_count"
  currentValue   Int                      @default(0)
  limit          Int?
  updatedAt      DateTime                 @updatedAt
  subscription   OrganizationSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, metricName])
  @@map("usage_metric")
}

// ====== SECURITY & COMPLIANCE ======

model SecurityPolicy {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Password Policy
  minPasswordLength   Int     @default(8)
  requireUppercase    Boolean @default(true)
  requireNumbers      Boolean @default(true)
  requireSpecialChars Boolean @default(true)
  passwordExpiryDays  Int? // null = no expiry

  // 2FA/MFA
  mfaRequired        Boolean @default(false)
  mfaGracePeriodDays Int     @default(7)

  // Session Management
  sessionTimeoutMinutes Int @default(60)
  maxConcurrentSessions Int @default(5)

  // Brute Force Protection
  maxLoginAttempts Int @default(5)
  lockoutDuration  Int @default(15) // minutes

  // IP & Geofencing
  ipWhitelistEnabled Boolean  @default(false)
  allowedIPs         String[] @default([])
  restrictToCountry  String? // ISO country code if restricted

  // Audit Settings
  auditLogLevel String @default("STANDARD") // BASIC, STANDARD, DETAILED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("security_policy")
}

model CompliancePolicy {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Data Governance
  dataRetentionDays Int    @default(365)
  dataRegion        String @default("GLOBAL") // For multi-region routing

  // Compliance Frameworks
  gdprEnabled  Boolean @default(true)
  hipaaEnabled Boolean @default(false)
  soc2Enabled  Boolean @default(false)

  // Privacy Rights
  dataExportAllowed    Boolean @default(true)
  rightToForgetEnabled Boolean @default(true)
  consentRequired      Boolean @default(true)

  // Backup Strategy
  autoBackupEnabled   Boolean @default(true)
  backupFrequency     String  @default("daily") // daily, weekly
  backupRetentionDays Int     @default(30)

  // Version Control
  termsVersion   String?
  privacyVersion String?
  lastUpdated    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("compliance_policy")
}

model DataExportRequest {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  status     String    @default("pending") // pending, processing, completed, failed
  exportedAt DateTime?
  expiresAt  DateTime? // After 30 days

  downloadUrl String? // Signed URL to S3 or similar

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status])
  @@index([userId])
  @@map("data_export_request")
}
